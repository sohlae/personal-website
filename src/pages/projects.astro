---
import ArchiveLayout from '../layouts/ArchiveLayout.astro';
import { site } from '../data/site';

const title = `All projects | Josh Monreal`;
const description =
  'Project archive: dates, roles, and technologies across representative engagements.';
---

<ArchiveLayout {title} {description}>
  <p class="mb-8">
    <a
      href={import.meta.env.BASE_URL}
      class="group flex items-center gap-2 font-mono text-sm text-accent transition hover:text-accent-bright"
      data-astro-prefetch
    >
      <svg 
        xmlns="http://www.w3.org/2000/svg" 
        width="16" 
        height="16" 
        viewBox="0 0 24 24" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="2.5" 
        stroke-linecap="round" 
        stroke-linejoin="round" 
        class="transition-transform group-hover:-translate-x-1"
      >
        <path d="M19 12H5"></path>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Josh Monreal
    </a>
  </p>

  <div class="max-w-4xl">
    <h1 class="mb-3 text-4xl font-bold tracking-tight text-white-soft sm:text-5xl">All projects</h1>
    <p class="mb-10 max-w-prose body-copy">
      A concise archive of engagements and representative work.
    </p>

    <div class="overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full border-spacing-0 text-left text-sm">
          <thead class=" text-slate-lightest">
            <tr class="">
              <th scope="col" class="whitespace-nowrap px-4 py-4 text-xs font-medium uppercase tracking-[0.25em] text-slate-lightest">
                Year
              </th>
              <th scope="col" class="px-4 py-4 text-xs font-medium uppercase tracking-[0.25em] text-slate-lightest">
                Project
              </th>
              <th scope="col" class="hidden px-4 py-4 text-xs font-medium uppercase tracking-[0.25em] text-slate-lightest md:table-cell">
                Role
              </th>
              <th scope="col" class="hidden px-4 py-4 text-xs font-medium uppercase tracking-[0.25em] text-slate-lightest lg:table-cell">
                Tech stack
              </th>
            </tr>
          </thead>
          <tbody>
            {
              site.projectArchive.map((row) => (
                <tr>
                  <td class="whitespace-nowrap px-4 py-4 font-mono text-slate-light">{row.date}</td>
                  <td class="px-4 py-4 text-slate-lightest">{row.project}</td>
                  <td class="hidden px-4 py-4 text-slate md:table-cell">{row.role}</td>
                  <td class="hidden px-4 py-4 text-accent lg:table-cell">{row.techStack}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</ArchiveLayout>
