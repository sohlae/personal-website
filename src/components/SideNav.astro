---
import { navLinks } from '../data/nav';
import { site } from '../data/site';
import ContactBar from './ContactBar.astro';
---

<aside class="relative hidden shrink-0 lg:block lg:w-[42%]">
  <div class="sticky top-0 flex h-screen max-h-screen flex-col justify-between overflow-y-auto pt-22 pr-12">
    <div class="space-y-12">
      <div>
        <a href='/' class="text-5xl font-bold tracking-tight text-white-soft transition">
          Josh Monreal
        </a>
        <p class="mt-3 text-xl font-medium text-slate-light">{site.hero.role}</p>
        <p class="mt-5 max-w-xs body-copy">{site.hero.tagline}</p>
        <p class="mt-5 max-w-xs body-copy">{site.hero.contact}</p>
        
        <div class="flex items-center gap-4 mt-3">
          <ContactBar />
        </div>
      </div>

      <nav aria-label="Primary">
        <ul class="flex flex-col gap-4">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="nav-link" data-section-link>
                  <span>{link.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</aside>
