---
import { navLinks } from '../data/nav';
import { site } from '../data/site';
import profile from '../assets/josh.png';
import { Image } from 'astro:assets';
---

<aside class="relative hidden shrink-0 lg:block lg:w-[42%]">
  <div class="sticky top-0 flex h-screen max-h-screen flex-col justify-between overflow-y-auto py-10 pr-12">
    <div class="space-y-12">
      <div class="mb-6 mt-8 w-full max-w-68 bg-black rounded-sm">
        <Image
          src={profile}
          alt="Josh Monreal profile portrait"
          width={280}
          height={180}
          class="aspect-square w-full object-cover grayscale transition duration-300 hover:grayscale-0 mask-[radial-gradient(circle,black_95%,transparent_100%)]"
          loading="eager"
        />
      </div>

      <div>
        <a href={import.meta.env.BASE_URL} class="text-5xl font-bold tracking-tight text-white-soft transition">
          Josh Monreal
        </a>
        <p class="mt-3 text-xl font-medium text-slate-light">{site.hero.role}</p>
        <p class="mt-5 max-w-xs body-copy">{site.hero.tagline}</p>
        <p class="mt-5 max-w-xs body-copy">{site.hero.contact}</p>
        
        <div class="flex items-center gap-4 mt-3">
          <a
            href={site.contact.linkedin}
            class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
            target="_blank"
            rel="noreferrer"
            aria-label="LinkedIn"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 11.001-4.124 2.062 2.062 0 01-.001 4.124zM7.119 20.452H3.555V9h3.564v11.452z"
              />
            </svg>
          </a>
          <a
            href={`mailto:${site.contact.email}`}
            class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
            aria-label="Email"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M3.75 6.75h16.5v10.5H3.75z" />
              <path d="M3.75 7.5L12 13.5l8.25-6" />
            </svg>
          </a>
        </div>
      </div>

      <nav aria-label="Primary">
        <ul class="flex flex-col gap-4">
          {
            navLinks.map((link) => (
              <li>
                <a href={`${import.meta.env.BASE_URL}${link.href}`} class="nav-link" data-section-link>
                  <span>{link.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</aside>
