---
import { site } from '../data/site';
import ProjectCard from './ProjectCard.astro';
---

<section
  id="projects"
  class="mb-20 scroll-mt-24 lg:mb-28 lg:scroll-mt-8"
  aria-labelledby="projects-heading"
>
  <h2 id="projects-heading" class="section-heading">Projects</h2>
  <div class="space-y-20">
    {site.featuredProjects.map((project) => (
      <ProjectCard project={project} />
    ))}
  </div>
  <p class="mt-14">
    <a
      href={`${import.meta.env.BASE_URL}/projects`}
      class="group flex items-center gap-2 font-mono text-sm text-accent transition hover:text-accent-bright"
      data-astro-prefetch
    >
      View Full Project Archive
      <svg 
        xmlns="http://www.w3.org/2000/svg" 
        width="16" 
        height="16" 
        viewBox="0 0 24 24" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="2.5" 
        stroke-linecap="round" 
        stroke-linejoin="round" 
        class="transition-transform group-hover:translate-x-1"
      >
        <path d="M5 12h14"></path>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </p>
</section>
