---
import { site } from '../data/site';
import profile from '../assets/josh.png';
import { Image } from 'astro:assets';
import ContactBar from './ContactBar.astro';
---

<header class="mb-8 block lg:hidden flex flex-col items-center text-center">
  <div class="rounded-sm mb-6 w-full max-w-68 bg-black">
    <Image
      src={profile}
      alt="Josh Monreal profile portrait"
      width={180}
      height={180}
      class="aspect-square w-full object-cover mask-[radial-gradient(circle,black_95%,transparent_100%)]"
      loading="eager"
    />
  </div>

  <h1 class="text-4xl font-bold tracking-tight text-white-soft">
    Josh Monreal
  </h1>
  <p class="mt-3 text-xl font-semibold tracking-tight text-slate-light">{site.hero.role}</p>
  <p class="mt-4 max-w-prose text-lg leading-relaxed text-slate">
    <p>{site.hero.tagline}</p>
    <p>{site.hero.contact}</p>
  </p>


  <div class="mt-2 mb-6 flex items-center gap-4">
     <ContactBar />
  </div>
</header>
