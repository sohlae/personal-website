---
import { site } from '../data/site';
import profile from '../assets/josh.png';
import { Image } from 'astro:assets';
---

<header class="mb-8 block lg:hidden flex flex-col items-center text-center">
  <div class="rounded-sm mb-6 w-full max-w-68 bg-black">
    <Image
      src={profile}
      alt="Josh Monreal profile portrait"
      width={280}
      height={180}
      class="aspect-square w-full object-cover grayscale transition duration-300 hover:grayscale-0 mask-[radial-gradient(circle,black_95%,transparent_100%)]"
      loading="eager"
    />
  </div>

  <h1 class="text-4xl font-bold tracking-tight text-white-soft">
    Josh Monreal
  </h1>
  <p class="mt-3 text-xl font-semibold tracking-tight text-slate-light">{site.hero.role}</p>
  <p class="mt-4 max-w-prose text-lg leading-relaxed text-slate">
    <p>{site.hero.tagline}</p>
    <p>{site.hero.contact}</p>
  </p>


  <div class="mt-2 mb-6 flex items-center gap-4">
    <a
      href={site.contact.linkedin}
      class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
      target="_blank"
      rel="noreferrer"
      aria-label="LinkedIn"
    >
      <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 11.001-4.124 2.062 2.062 0 01-.001 4.124zM7.119 20.452H3.555V9h3.564v11.452z"
        />
      </svg>
    </a>
    <a
      href={`mailto:${site.contact.email}`}
      class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
      aria-label="Email"
    >
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M3.75 6.75h16.5v10.5H3.75z" />
        <path d="M3.75 7.5L12 13.5l8.25-6" />
      </svg>
    </a>
  </div>
</header>
