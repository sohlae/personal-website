---
import { site } from '../data/site';
import profile from '../assets/josh.png';
import { Image } from 'astro:assets';
---

<header class="mb-8 block lg:hidden">
  <div class="rounded-sm mb-6 w-full max-w-88 bg-black">
    <Image
      src={profile}
      alt="Josh Monreal profile portrait"
      width={280}
      height={180}
      class="aspect-square w-full object-cover grayscale transition duration-300 hover:grayscale-0 mask-[radial-gradient(circle,black_95%,transparent_100%)]"
      loading="eager"
    />
  </div>

  <h1 class="text-4xl font-bold tracking-tight text-white-soft">
    Josh Monreal
  </h1>
  <p class="mt-3 text-xl font-semibold tracking-tight text-slate-light">{site.hero.role}</p>
  <p class="mt-4 max-w-prose text-lg leading-relaxed text-slate">{site.hero.tagline}</p>
  <div class="mt-6 flex items-center gap-4">
    <a
      href={site.contact.github}
      class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
      target="_blank"
      rel="noreferrer"
      aria-label="GitHub"
    >
      <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
        <path
          d="M12 .5a12 12 0 00-3.793 23.384c.6.111.82-.26.82-.577v-2.23c-3.338.726-4.042-1.61-4.042-1.61-.546-1.386-1.333-1.755-1.333-1.755-1.09-.745.082-.73.082-.73 1.205.086 1.84 1.239 1.84 1.239 1.07 1.833 2.808 1.304 3.493.997.108-.775.418-1.304.761-1.604-2.665-.303-5.467-1.332-5.467-5.93 0-1.31.468-2.382 1.236-3.222-.124-.303-.536-1.523.117-3.174 0 0 1.008-.322 3.3 1.23A11.5 11.5 0 0112 6.317a11.5 11.5 0 013.005.404c2.29-1.552 3.297-1.23 3.297-1.23.655 1.651.243 2.87.12 3.174.77.84 1.235 1.911 1.235 3.222 0 4.61-2.807 5.623-5.48 5.92.43.37.814 1.102.814 2.222v3.293c0 .32.218.694.825.576A12 12 0 0012 .5z"
        />
      </svg>
    </a>
    <a
      href={site.contact.linkedin}
      class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
      target="_blank"
      rel="noreferrer"
      aria-label="LinkedIn"
    >
      <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 11.001-4.124 2.062 2.062 0 01-.001 4.124zM7.119 20.452H3.555V9h3.564v11.452z"
        />
      </svg>
    </a>
    <a
      href={`mailto:${site.contact.email}`}
      class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
      aria-label="Email"
    >
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M3.75 6.75h16.5v10.5H3.75z" />
        <path d="M3.75 7.5L12 13.5l8.25-6" />
      </svg>
    </a>
  </div>
</header>
