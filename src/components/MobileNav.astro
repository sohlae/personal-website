---
import { navLinks } from '../data/nav';
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-navy-lighter bg-navy/90 backdrop-blur-md lg:hidden"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 md:px-8">
    <a href="/" class="text-base font-bold text-white-soft">Josh Monreal</a>
    <button
      type="button"
      id="menu-btn"
      class="inline-flex items-center justify-center rounded-sm border border-accent/50 px-3 py-2 font-mono text-xs uppercase tracking-wider text-accent transition hover:bg-navy-light"
      aria-expanded="false"
      aria-controls="mobile-panel"
      aria-label="Open menu"
    >
      Menu
    </button>
  </div>
  <div id="mobile-panel" class="hidden border-b border-navy-lighter bg-navy px-4 py-4 sm:px-6 md:px-8">
    <nav aria-label="Primary">
      <ul class="flex flex-col gap-4">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="nav-link block w-fit" data-section-link>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
