---
import { site } from '../data/site';
---

<section id="contact" class="scroll-mt-24 lg:scroll-mt-8" aria-labelledby="contact-heading">
  <h2 id="contact-heading" class="section-heading">Contact</h2>
  <p class="mb-8 max-w-prose text-slate-400">{site.contact.line}</p>
  <div class="flex flex-wrap items-center gap-6">
    <a
      href={`mailto:${site.contact.email}`}
      class="rounded-lg border border-transparent p-2 text-slate-300 transition hover:border-accent/50 hover:text-accent-bright"
      aria-label="Email"
    >
      <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
        <path d="M4 6h16v12H4z" stroke-linejoin="round" />
        <path d="M4 7l8 6 8-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
    <a
      href={site.contact.linkedin}
      class="rounded-lg border border-transparent p-2 text-slate-300 transition hover:border-accent/50 hover:text-accent-bright"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn"
    >
      <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        />
      </svg>
    </a>
  </div>
</section>
