---
import { site } from '../data/site';
---

<section class="mb-16 max-w-prose lg:mb-24" aria-labelledby="hero-heading">
  <h1 id="hero-heading" class="mb-2 text-4xl font-bold tracking-tight text-white-soft sm:text-5xl">
    {site.hero.name}
  </h1>
  <p class="mb-4 text-2xl font-semibold tracking-tight text-slate-light">{site.hero.role}</p>
  <p class="mb-8 text-lg leading-relaxed text-slate">{site.hero.tagline}</p>
</section>
